generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Submission: one row per ODK submission. Columns match SVC data types.
// Groups (form sections) are not modelled as separate tables.
// Full payload also stored in `data` (Json) for flexibility.
// ---------------------------------------------------------------------------
model Submission {
  id              String    @id // ODK __id
  data            Json      // Full OData payload
  submissionDate  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // ---- Section A: Respondent / facility (String, DateTime) ----
