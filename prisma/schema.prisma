model SyncLog {
  id                  Int       @id @default(autoincrement())
  startedAt           DateTime  @default(now())
  finishedAt          DateTime?
  status              SyncStatus
  message             String?
  lastSubmissionDate  DateTime?
}

model User {
  id                 Int                @id @default(autoincrement())
  email              String             @unique
  passwordHash       String
  role               Role
  jurisdictionLevel  JurisdictionLevel
  region             String?
  district           String?
  facility           String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime?          @updatedAt
}

enum Role {
  ADMIN
  NATIONAL
  REGIONAL
  DISTRICT
  FACILITY
}

enum JurisdictionLevel {
  NATIONAL
  REGIONAL
  DISTRICT
  FACILITY
}

enum SyncStatus {
  SUCCESS
  FAILED
  RUNNING
}
